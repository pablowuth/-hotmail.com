{
  "openapi": "3.0.3",
  "info": {
    "title": "Nexus Control Plane",
    "version": "2.2.0",
    "description": "Puente ChatGPT ↔ Nexus ↔ Cursor. POST /v1/prompt encola (202). GET /v1/tasks/{taskId} devuelve resultado (200)."
  },
  "servers": [
    {
      "url": "https://nexus-control-plane.onrender.com",
      "description": "Nexus public bridge"
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Estado del control plane",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/prompt": {
      "post": {
        "operationId": "enqueuePrompt",
        "summary": "Encolar instrucción para ejecución (Cursor vía Nexus)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["prompt"],
                "properties": {
                  "prompt": { "type": "string", "description": "Instrucción a ejecutar" },
                  "workspace": { "type": "string" },
                  "metadata": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Tarea encolada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "taskId": { "type": "string" },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{taskId}": {
      "get": {
        "operationId": "getTask",
        "summary": "Obtener resultado de la tarea",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Tarea completada o en progreso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "task": { "type": "object" },
                    "events": { "type": "array" }
                  }
                }
              }
            }
          },
          "404": { "description": "No encontrada" }
        }
      }
    }
  }
}
