{
  "openapi": "3.0.3",
  "info": {
    "title": "Nexus Control Plane",
    "version": "2.1.0",
    "description": "API async de Nexus para ChatGPT. Requiere API key. POST /v1/prompt devuelve 202; consultar estado con GET /v1/tasks/{taskId}."
  },
  "servers": [
    {
      "url": "https://nexus-control-plane.onrender.com",
      "description": "Render free (permanente tras deploy)"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "NEXUS_API_KEY — configurar en ChatGPT Actions como API Key / Bearer"
      }
    }
  },
  "security": [{ "ApiKeyAuth": [] }],
  "paths": {
    "/v1/prompt": {
      "post": {
        "operationId": "enqueuePrompt",
        "summary": "Encolar un prompt (respuesta inmediata 202)",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["prompt"],
                "properties": {
                  "prompt": { "type": "string" },
                  "workspace": { "type": "string" },
                  "metadata": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Tarea encolada" },
          "401": { "description": "API key inválida o faltante" }
        }
      }
    },
    "/v1/tasks/{taskId}": {
      "get": {
        "operationId": "getTask",
        "summary": "Consultar estado de una tarea",
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Tarea y eventos" },
          "401": { "description": "API key inválida o faltante" },
          "404": { "description": "No encontrada" }
        }
      }
    }
  }
}
